<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>语音实时识别服务 - 业务流程图</title>
  </head>
  <body>
    <outline text="语音实时识别服务">
      <outline text="开始">
        <outline text="店员点击开始录音"/>
      </outline>
      <outline text="初始化">
        <outline text="连接阿里云语音识别服务"/>
        <outline text="建立WebSocket长连接"/>
      </outline>
      <outline text="录音中">
        <outline text="麦克风采集顾客与店员对话"/>
        <outline text="音频流实时上传至云端"/>
        <outline text="云端实时转写为文字"/>
        <outline text="转写结果实时返回"/>
      </outline>
      <outline text="结束录音">
        <outline text="店员点击停止录音"/>
        <outline text="断开WebSocket连接"/>
        <outline text="释放麦克风资源"/>
      </outline>
      <outline text="结束"/>
    </outline>
  </body>
</opml>
